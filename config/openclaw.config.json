{
  "$schema": "https://openclaw.ai/config-schema.json",
  "_comment": "OpenClawMax — конфигурация с нативным GigaChat плагином",

  "models": {
    "default": "gigachat/GigaChat-Max",
    "providers": {
      "gigachat": {
        "baseUrl": "https://gigachat.devices.sberbank.ru/api/v1",
        "api": "openai-completions",
        "auth": "oauth",
        "models": [
          {
            "id": "GigaChat",
            "name": "GigaChat",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 8192,
            "maxTokens": 4096
          },
          {
            "id": "GigaChat-Plus",
            "name": "GigaChat Plus",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "GigaChat-Pro",
            "name": "GigaChat Pro",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "GigaChat-Max",
            "name": "GigaChat Max",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 16384
          }
        ]
      }
    }
  },

  "channels": {
    "max": {
      "enabled": true
    },
    "telegram": {
      "enabled": true
    }
  },

  "extensions": [
    "./extensions/gigachat",
    "./extensions/max"
  ],

  "agent": {
    "language": "ru",
    "defaultGreeting": "Привет! Я ваш AI-ассистент на базе GigaChat. Чем могу помочь?"
  }
}
