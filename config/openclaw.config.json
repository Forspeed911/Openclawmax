{
  "$schema": "https://openclaw.ai/config-schema.json",
  "_comment": "OpenClawMax — конфигурация с нативным GigaChat плагином",

  "models": {
    "default": "gigachat/GigaChat-2-Max",
    "providers": {
      "gigachat": {
        "baseUrl": "https://gigachat.devices.sberbank.ru/api/v1",
        "api": "openai-completions",
        "auth": "oauth",
        "models": [
          {
            "id": "GigaChat-2",
            "name": "GigaChat 2 Lite",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "GigaChat-2-Pro",
            "name": "GigaChat 2 Pro",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "GigaChat-2-Max",
            "name": "GigaChat 2 Max",
            "reasoning": false,
            "input": ["text", "image", "audio"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "channels": {
    "max": {
      "enabled": true
    },
    "telegram": {
      "enabled": true
    }
  },

  "extensions": [
    "./extensions/gigachat",
    "./extensions/max"
  ],

  "agents": {
    "defaults": {
      "language": "ru",
      "defaultGreeting": "Привет! Я ваш AI-ассистент на базе GigaChat. Чем могу помочь?"
    }
  }
}
