{
  "$schema": "https://openclaw.ai/config-schema.json",
  "_comment": "OpenClawMax — GigaChat через gpt2giga прокси + Max/Telegram",

  "agents": {
    "defaults": {
      "model": "gigachat/GigaChat-2-Max",
      "contextTokens": 32000,
      "thinkingDefault": "off",
      "compaction": { "mode": "default" }
    }
  },

  "models": {
    "default": "GigaChat-2-Max",
    "providers": {
      "gigachat": {
        "baseUrl": "http://gpt2giga:8090/v1",
        "api": "openai-completions",
        "apiKey": "gpt2giga-local",
        "_comment": "gpt2giga прокси транслирует OpenAI → GigaChat API (OAuth внутри)",
        "models": [
          {
            "id": "GigaChat-2-Max",
            "name": "GigaChat 2 Max",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 8192,
            "compat": {
              "supportsTools": true,
              "supportsStrictMode": false,
              "supportsDeveloperRole": false,
              "supportsReasoningEffort": false,
              "maxTokensField": "max_tokens"
            }
          },
          {
            "id": "GigaChat-2-Pro",
            "name": "GigaChat 2 Pro",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 8192,
            "compat": {
              "supportsTools": true,
              "supportsStrictMode": false,
              "supportsDeveloperRole": false,
              "supportsReasoningEffort": false,
              "maxTokensField": "max_tokens"
            }
          },
          {
            "id": "GigaChat-2",
            "name": "GigaChat 2 Lite",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 8192,
            "compat": {
              "supportsTools": true,
              "supportsStrictMode": false,
              "supportsDeveloperRole": false,
              "supportsReasoningEffort": false,
              "maxTokensField": "max_tokens"
            }
          }
        ]
      }
    }
  },

  "channels": {
    "max": { "enabled": true },
    "telegram": { "enabled": true }
  },

  "gateway": {
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  }
}
