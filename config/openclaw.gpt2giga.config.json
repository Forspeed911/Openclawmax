{
  "$schema": "https://openclaw.ai/config-schema.json",
  "_comment": "OpenClawMax — конфигурация через gpt2giga proxy",

  "models": {
    "default": "GigaChat-Max",
    "providers": {
      "openai": {
        "baseUrl": "http://gpt2giga:8090/v1",
        "api": "openai-completions",
        "apiKey": "gpt2giga-local",
        "_comment": "gpt2giga proxy транслирует OpenAI формат в GigaChat API",
        "models": [
          {
            "id": "GigaChat",
            "name": "GigaChat (через gpt2giga)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 8192,
            "maxTokens": 4096
          },
          {
            "id": "GigaChat-Plus",
            "name": "GigaChat Plus (через gpt2giga)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "GigaChat-Pro",
            "name": "GigaChat Pro (через gpt2giga)",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "GigaChat-Max",
            "name": "GigaChat Max (через gpt2giga)",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 16384
          }
        ]
      }
    }
  },

  "channels": {
    "max": {
      "enabled": true
    },
    "telegram": {
      "enabled": true
    }
  },

  "extensions": [
    "./extensions/max"
  ],

  "agent": {
    "language": "ru",
    "defaultGreeting": "Привет! Я ваш AI-ассистент на базе GigaChat. Чем могу помочь?"
  }
}
