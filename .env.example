# ============================================
# OpenClawMax — Переменные окружения
# ============================================
# Скопируй этот файл: cp .env.example .env
# Заполни нужные значения и запусти: docker compose up -d

# --- GigaChat (Sber) ---
# Получить: https://developers.sber.ru → Создать проект → API ключи
# Формат: Base64(client_id:client_secret)
GIGACHAT_CREDENTIALS=

# Scope: GIGACHAT_API_PERS (физлица, бесплатно) | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель по умолчанию (для gpt2giga варианта)
GIGACHAT_MODEL=GigaChat-Max

# --- Max Messenger (VK) ---
# Получить: https://dev.max.ru → Создать бота → Скопировать токен
# Важно: доступ только для юрлиц / ИП — резидентов РФ
MAX_BOT_TOKEN=

# --- Telegram (опционально) ---
# Получить: @BotFather в Telegram
TELEGRAM_BOT_TOKEN=

# --- Сервер ---
# Порт OpenClaw (по умолчанию 3000)
OPENCLAW_PORT=3000

# URL для вебхуков (нужен для Max и Telegram в production)
# Пример: https://bot.yourdomain.ru
WEBHOOK_BASE_URL=

# --- Домен (для Caddy / SSL) ---
# Если указан — Caddy автоматически получит Let's Encrypt сертификат
# Если пусто — работает на localhost без SSL
DOMAIN=
