# ============================================
# OpenClawMax — Переменные окружения
# ============================================
# Скопируй: cp .env.example .env
# Заполни и запусти: docker compose up -d
# Или используй install.sh: bash scripts/install.sh

# --- GigaChat (Sber) ---
# Получить: https://developers.sber.ru → Создать проект → API ключи
# Формат: Base64(client_id:client_secret)
GIGACHAT_AUTH_KEY=

# Scope: GIGACHAT_API_PERS (физлица, бесплатно) | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель по умолчанию: GigaChat-2 (Lite) | GigaChat-2-Pro | GigaChat-2-Max
GIGACHAT_MODEL=GigaChat-2-Max

# --- Max Messenger ---
# Получить: https://dev.max.ru → Создать бота → Скопировать токен
# Доступ к API: юрлица и ИП — резиденты РФ
MAX_BOT_TOKEN=

# --- Telegram (опционально) ---
# Получить: @BotFather в Telegram
TELEGRAM_BOT_TOKEN=

# --- Сервер ---
OPENCLAW_PORT=3000

# URL для вебхуков (production, если есть домен)
# Пример: https://bot.yourdomain.ru
WEBHOOK_BASE_URL=

# --- Домен (для Caddy / SSL) ---
# Если указан — Caddy получит Let's Encrypt сертификат автоматически
# Если пусто — работает на localhost без SSL
DOMAIN=
