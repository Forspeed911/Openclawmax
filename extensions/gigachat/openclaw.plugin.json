{
  "id": "gigachat",
  "providers": ["gigachat"],

  "providerAuthEnvVars": {
    "gigachat": ["GIGACHAT_CREDENTIALS", "GIGACHAT_CLIENT_ID", "GIGACHAT_CLIENT_SECRET"]
  },

  "providerAuthChoices": [
    {
      "provider": "gigachat",
      "method": "api-key",
      "choiceId": "gigachat-credentials",
      "choiceLabel": "GigaChat credentials (client_id:client_secret)",
      "choiceHint": "Base64(client_id:client_secret) from developers.sber.ru",
      "groupId": "gigachat",
      "groupLabel": "GigaChat (Sber)",
      "groupHint": "Российская LLM от Сбера",
      "optionKey": "gigachatCredentials",
      "cliFlag": "--gigachat-credentials",
      "cliOption": "--gigachat-credentials <credentials>",
      "cliDescription": "GigaChat credentials (base64 of client_id:client_secret)"
    }
  ],

  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "scope": {
        "type": "string",
        "enum": ["GIGACHAT_API_PERS", "GIGACHAT_API_B2B", "GIGACHAT_API_CORP"],
        "default": "GIGACHAT_API_PERS",
        "description": "GigaChat API scope: PERS (personal), B2B (business), CORP (corporate)"
      }
    }
  },

  "uiHints": {
    "scope": {
      "label": "API Scope",
      "help": "PERS = физлица (бесплатно), B2B = бизнес, CORP = корпоративный"
    }
  }
}
